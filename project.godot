; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Soulslike 3D"
config/description="Juego 3D de acción tipo soulslike ambientado en la cultura mapuche, de código abierto, hecho con Godot. (Título provisional)"
run/main_scene="res://scenes/ui/main_menu.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GameFeel="*res://scripts/autoload/game_feel.gd"
GameState="*res://scripts/autoload/game_state.gd"
Settings="*res://scripts/autoload/settings.gd"
UiState="*res://scripts/autoload/ui_state.gd"
PauseMenu="*res://scenes/ui/pause_menu.tscn"
InventoryMenu="*res://scenes/ui/inventory_menu.tscn"

